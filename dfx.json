{
  "canisters": {
    "dcss-crypto-hub-backend": {
      "candid": "src/dcss-crypto-hub-backend/main.did",
      "main": "src/backend/main.mo",
      "type": "motoko"
    },
    "dcss-crypto-hub-frontend": {
      "dependencies": ["dcss-crypto-hub-backend"],
      "source": ["src/frontend/dist"],
      "type": "assets"
    }
  },
  "defaults": {
    "build": {
      "args": "",
      "packtool": ""
    }
  },
  "networks": {
    "ic": {
      "providers": ["https://icp0.io"],
      "type": "persistent"
    },
    "playground": {
      "providers": ["https://icp0.io"],
      "type": "ephemeral"
    },
    "local": {
      "bind": "127.0.0.1:4943",
      "type": "ephemeral"
    }
  },
  "output_env_file": ".env",
  "version": 1
}
